{
  "compilerOptions": {
    "target": "es2025",
    "types": [
      "node",
      "@types/openui5"
    ],
    "skipLibCheck": true,
    "allowJs": true,
    "strictPropertyInitialization": false,
    "rootDir": "./webapp",
    "paths": {
      "ui5/quickstart/*": [
        "./webapp/*"
      ]
    }
  },
  "include": [
    "./webapp/**/*"
  ]
}
